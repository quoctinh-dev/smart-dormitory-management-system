# SmartAccess API Endpoints
# Base URL and authentication variables (reuse from auth.http)
@host = http://localhost:8080
@access_token = {{access_token}}

# ------------------------------------------------------------
# 1. Access History
# ------------------------------------------------------------
### Get all access history (paginated)
GET {{host}}/api/v1/access/history
Authorization: Bearer {{access_token}}
Content-Type: application/json

### Get access history for a specific student (paginated)
GET {{host}}/api/v1/access/history/student/{{studentId}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

# ------------------------------------------------------------
# 2. Curfew Policies
# ------------------------------------------------------------
### Create a new curfew policy
POST {{host}}/api/v1/access/curfew-policies
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "buildingId": "{{buildingId}}",
  "residentType": "BOARDING",
  "startTime": "22:00:00",
  "endTime": "06:00:00",
  "type": "STRICT",
  "priority": 1,
  "isActive": true
}

### Update curfew policy status
PUT {{host}}/api/v1/access/curfew-policies/{{policyId}}/status?isActive={{isActive}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

# ------------------------------------------------------------
# 3. Time Window Policies
# ------------------------------------------------------------
### Create a new time window policy
POST {{host}}/api/v1/access/time-window-policies
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "buildingId": "{{buildingId}}",
  "residentType": "NON_BOARDING",
  "startTime": "08:00:00",
  "endTime": "18:00:00",
  "isActive": true
}

### Update time window policy status
PUT {{host}}/api/v1/access/time-window-policies/{{policyId}}/status?isActive={{isActive}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

# ------------------------------------------------------------
# 4. Emergency Override
# ------------------------------------------------------------
### Execute emergency override
POST {{host}}/api/v1/access/emergency?actionType={{actionType}}&reason={{reason}}&buildingId={{buildingId}}
Authorization: Bearer {{access_token}}
Content-Type: application/json

# ------------------------------------------------------------
# 5. Remote Unlock
# ------------------------------------------------------------
### Unlock a gate remotely
POST {{host}}/api/v1/access/gates/{{gateId}}/unlock?buildingId={{buildingId}}
Authorization: Bearer {{access_token}}
Content-Type: application/json